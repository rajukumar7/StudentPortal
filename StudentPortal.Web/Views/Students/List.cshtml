@{
}

@* Binding the AddStudentViewModel to List.cshtml *@

@* Its only for view or usually display data, not modify it. *@
@* @model IEnumerable<StudentPortal.Web.Models.Entities.Student> *@ 

@model List<StudentPortal.Web.Models.Entities.Student>


<h2>Student List</h2>
@* Add Student  *@
<a asp-controller="Students" asp-action="Add" class="btn btn-success mb-3">Add Student</a>

<table class="table">
    <thead>
        <tr>    
            <th>Name</th>
            <th>Email</th>
            <th>Phone</th>
            <th>Enrollment Date</th>
            <th>Is Active</th>
            <th>Action</th>
        </tr>
    </thead>
    <tbody>
        @foreach(var student in Model){
            <tr>
                <td>@student.Name</td>
                <td>@student.Email</td>
                <td>@student.Phone</td>
                <td>@student.EnrollmentDate.ToString("yyyy-MM-dd")</td>
                <td>@(student.IsActive ? "Yes" : "No")</td>
                <td>
                    <a asp-controller="Students" asp-action="Edit" asp-route-id="@student.Id" class="btn btn-sm btn-primary">Edit</a>
                    <a asp-controller="Students" asp-action="Details" asp-route-id="@student.Id" class="btn btn-sm btn-info">Detail</a>
                    @*  <a asp-controller="Students" asp-action="Delete" asp-route-id="@student.Id" class="btn btn-sm btn-danger">Delete</a> *@
                </td>
            </tr>
        }
    </tbody>
</table>

